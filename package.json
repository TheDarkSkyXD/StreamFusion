{
    "name": "streamfusion-monorepo",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "start": "npm start --prefix apps/desktop",
        "desktop": "npm start --workspace=streamfusion",
        "build": "npm run build --workspace=streamfusion",
        "dist": "npm run dist --workspace=streamfusion",
        "dist:win": "npm run dist:win --workspace=streamfusion",
        "dist:mac": "npm run dist:mac --workspace=streamfusion",
        "dist:linux": "npm run dist:linux --workspace=streamfusion",
        "lint": "npm run lint --workspace=streamfusion",
        "test": "npm test --workspace=streamfusion",
        "typecheck": "npm run typecheck --workspace=streamfusion"
    }
}